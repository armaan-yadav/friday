# ============================================================================
# Friday Voice Assistant — Environment Configuration
# ============================================================================
# Copy this file to .env and customize values for your environment
# ============================================================================

# ============================================================================
# TRANSCRIPTION (STT) — faster-whisper Configuration
# ============================================================================

# Model size: tiny, base, small, medium, large, large-v3
# Larger = higher accuracy but slower (large-v3 ~10GB RAM, 2-3 sec per utterance)
STT_MODEL_SIZE=large-v3

# Language code: en, hi, es, fr, de, etc.
# Use "en" for English, "hi" for Hindi, etc.
STT_LANGUAGE=hi

# Task: transcribe (keep original language) or translate (translate to English)
STT_TASK=translate

# Audio sample rate (Hz) — standard 16kHz for Whisper
STT_SAMPLE_RATE=16000

# Device: cuda (NVIDIA GPU, fast) or cpu (slow but compatible)
STT_WHISPER_DEVICE=cuda

# Compute type: float16 (GPU), float32 (CPU), int8 (quantized)
STT_COMPUTE_TYPE=float16

# Wake-word phrases (comma-separated, case-insensitive)
STT_WAKE_WORDS=hey friday

# Timeout after wake-word detected waiting for query (seconds)
STT_WAKE_WORD_TIMEOUT=8.0

# Inactivity timeout before returning to sleep (seconds)
STT_CONVERSATION_TIMEOUT=12.0

# ============================================================================
# VOICE ACTIVITY DETECTION (VAD) — Microphone Audio Processing
# ============================================================================

# RMS (root mean square) energy threshold for detecting speech
# Higher = requires louder speech to detect (less false positives)
# Lower = detects quieter speech (more false positives)
STT_SILENCE_THRESHOLD=0.01

# Duration of silence (seconds) before ending utterance capture
STT_SILENCE_DURATION=1.5

# Minimum speech duration (seconds) to process as valid utterance
STT_MIN_SPEECH_DURATION=0.5

# Audio block size in samples (0.1 sec at 16kHz = 1600 samples)
STT_BLOCK_SIZE=1600

# ============================================================================
# LLM (LANGUAGE MODEL) — LM Studio Configuration
# ============================================================================

# LM Studio OpenAI-compatible API endpoint
# Default: http://localhost:1234/v1/chat/completions
# Remote example: http://192.168.1.5:1234/v1/chat/completions
LLM_STUDIO_URL=http://192.168.1.5:1234/v1/chat/completions

# Model name as shown in LM Studio (must match loaded model)
# Examples: google/gemma-4-e4b, meta-llama/Llama-2-7b, mistral-7b
LLM_MODEL=google/gemma-4-e4b

# System prompt — defines assistant personality and behavior
LLM_SYSTEM_PROMPT=You are a voice assistant named Friday.\n\nKeep responses short, natural, and conversational.\nNo markdown, no bullet points, no headers.\nRespond as you would speak out loud.

# Temperature: 0.0 (deterministic) to 1.0+ (creative)
# 0.7 = balanced (default)
LLM_TEMPERATURE=0.7

# Maximum tokens in response (~4 chars per token, so 300 tokens ≈ 75 words)
LLM_MAX_OUTPUT_TOKENS=300

# HTTP request timeout (seconds)
LLM_REQUEST_TIMEOUT=30

# ============================================================================
# TEXT-TO-SPEECH (TTS) — Kokoro Configuration
# ============================================================================

# Language code: a (American English), b (British English), etc.
TTS_KOKORO_LANG=a

# Voice: af_heart (warm female), am_michael (male), etc.
TTS_KOKORO_VOICE=af_heart

# Sample rate (Kokoro always outputs 24kHz, don't change)
TTS_KOKORO_SAMPLE_RATE=24000

# ============================================================================
# BARGE-IN (Interrupt Detection) — Microphone Monitoring During Speech
# ============================================================================

# RMS energy threshold for detecting user speech during TTS playback
# Higher = user must speak louder to interrupt (fewer false interrupts)
# Lower = easier to interrupt but may respond to noise/echo
TTS_BARGE_IN_THRESHOLD=0.02

# Number of consecutive loud blocks required to trigger interrupt
# 1 = immediate (hair-trigger), 3 = ~30ms of speech needed (balanced)
TTS_BARGE_IN_CONFIRM_BLOCKS=3

# ============================================================================
# WEB UI & SERVER
# ============================================================================

# HTTP server port for web UI
# Access at: http://localhost:PORT
SERVER_PORT=5000

# Output file for transcript persistence (stores conversation history)
SERVER_OUTPUT_JSON=transcripts.json

# Mute flag file path (created/deleted to mute microphone)
SERVER_MUTE_FLAG_PATH=muted.flag

# ============================================================================
# WEB SEARCH — SearXNG + Jina Reader
# ============================================================================

# SearXNG search API endpoint (self-hosted search engine)
# Must be running locally via Docker: docker run -d -p 8888:8888 searxng/searxng
# Or set to your deployment: http://your-searxng-instance:8888/search
SEARCH_SEARXNG_URL=http://localhost:8888/search

# Jina Reader API endpoint for fetching full page content as plain text
# Free public API (no auth required)
SEARCH_JINA_URL=https://r.jina.ai/

# Number of search results to fetch from SearXNG per query
# Higher = more comprehensive but slower
SEARCH_NUM_RESULTS=4

# How many of those results to fetch full page content for via Jina
# Full page fetching takes time, so keep this low (2-3 recommended)
SEARCH_FETCH_FULL_PAGES=2

# Maximum characters to include from each full page
# Prevents bloating the LLM context window with too much text
SEARCH_MAX_PAGE_CHARS=1500

# HTTP request timeout for SearXNG search query (seconds)
SEARCH_TIMEOUT=8

# HTTP request timeout for Jina Reader page fetch (seconds)
SEARCH_JINA_TIMEOUT=12

# ============================================================================
# LOGGING & DEBUG
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
# DEBUG = verbose, INFO = normal, WARNING/ERROR = minimal
LOG_LEVEL=INFO
